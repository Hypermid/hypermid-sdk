{
  "name": "@hypermid/sdk",
  "version": "2.1.0",
  "description": "Cross-chain swap, bridge & fiat on-ramp SDK — 90+ chains across EVM, Solana, Bitcoin, NEAR, Sui, Tron, TON. Multi-ecosystem wallet balances, partner webhooks, anonymous-tier ready (no API key required).",
  "homepage": "https://docs.hypermid.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hypermid/hypermid-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/Hypermid/hypermid-sdk/issues"
  },
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs",
    "build:esm": "tsc -p tsconfig.json && echo '{\"type\":\"module\"}' > dist/esm/package.json",
    "build:cjs": "tsc -p tsconfig.cjs.json && echo '{\"type\":\"commonjs\"}' > dist/cjs/package.json",
    "dev": "tsc -p tsconfig.json --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "hypermid",
    "swap",
    "bridge",
    "cross-chain",
    "cross-chain-swap",
    "bridge-aggregator",
    "dex-aggregator",
    "swap-api",
    "bridge-api",
    "defi",
    "defi-sdk",
    "web3",
    "web3-sdk",
    "ethereum",
    "evm",
    "solana",
    "bitcoin",
    "near",
    "near-intents",
    "sui",
    "tron",
    "ton",
    "pulsechain",
    "onramp",
    "fiat-onramp",
    "wallet-balances",
    "multi-chain",
    "webhooks",
    "typescript",
    "esm",
    "commonjs"
  ],
  "author": "Hypermid",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
